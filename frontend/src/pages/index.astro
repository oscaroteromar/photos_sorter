---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Photos Sorter — Sort your photos by date" description="A desktop app that reads each photo's date and copies it into a tidy Year / Month folder tree. Free and open source.">

<div style="min-height:100vh;background:var(--bg);color:var(--ink);">

  <!-- ============ NAV ============ -->
  <header style="position:sticky;top:0;z-index:30;background:color-mix(in srgb, var(--bg) 82%, transparent);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom:1px solid var(--line2);">
    <div style="max-width:1140px;margin:0 auto;padding:14px 28px;display:flex;align-items:center;gap:16px;">
      <a href="#top" style="display:flex;align-items:center;gap:11px;text-decoration:none;">
        <svg width="34" height="34" viewBox="0 0 512 512" style="border-radius:9px;display:block;"><use href="#psIcon" /></svg>
        <span style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:18px;letter-spacing:-.3px;color:var(--ink);">Photos Sorter</span>
      </a>
      <div style="margin-left:auto;display:flex;align-items:center;gap:10px;flex-wrap:wrap;justify-content:flex-end;">
        <!-- Language segmented control -->
        <div style="display:flex;border:1px solid var(--line);border-radius:999px;padding:3px;">
          <button
            id="ps-lang-en"
            data-base-style="padding:6px 14px;border:none;border-radius:999px;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:13px;cursor:pointer;transition:all .15s;line-height:1;"
            style="padding:6px 14px;border:none;border-radius:999px;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:13px;cursor:pointer;transition:all .15s;line-height:1;background:var(--inv);color:var(--invInk);"
          >EN</button>
          <button
            id="ps-lang-es"
            data-base-style="padding:6px 14px;border:none;border-radius:999px;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:13px;cursor:pointer;transition:all .15s;line-height:1;"
            style="padding:6px 14px;border:none;border-radius:999px;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:13px;cursor:pointer;transition:all .15s;line-height:1;background:transparent;color:var(--muted);"
          >ES</button>
        </div>
        <!-- Theme toggle -->
        <button
          id="ps-theme-btn"
          aria-label="Toggle theme"
          style="width:38px;height:38px;display:flex;align-items:center;justify-content:center;border:1px solid var(--line);border-radius:11px;background:transparent;color:var(--ink);cursor:pointer;"
        >
          <!-- Moon icon default (overridden by JS) -->
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 14.5A8 8 0 1 1 9.5 4 6.5 6.5 0 0 0 20 14.5z"/></svg>
        </button>
      </div>
    </div>
  </header>

  <main id="ps-main">
  <span id="top"></span>

  <!-- ============ HERO ============ -->
  <section class="ps-hero" style="max-width:1140px;margin:0 auto;padding:72px 28px 36px;display:grid;grid-template-columns:1.04fr .96fr;gap:54px;align-items:center;">
    <!-- Block A: badge + title + tagline -->
    <div class="ps-hero-a" style="animation:psFade .5s ease both;">
      <div style="display:inline-flex;align-items:center;gap:8px;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:12px;letter-spacing:.05em;color:var(--muted);background:var(--surface);border:1px solid var(--line);padding:7px 13px;border-radius:999px;">
        <span style="width:7px;height:7px;border-radius:50%;background:var(--ink);display:inline-block;"></span>
        <span data-i18n="hero.badge">Free · open source · Tkinter desktop app</span>
      </div>
      <h1 style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:clamp(36px,5.2vw,58px);line-height:1.03;letter-spacing:-1.8px;color:var(--ink);margin:20px 0 0;text-wrap:balance;" data-i18n="hero.title">Sort your photos by the day they were taken.</h1>
      <p style="font-size:18px;line-height:1.6;color:var(--muted);max-width:31em;margin:22px 0 0;text-wrap:pretty;" data-i18n="hero.tagline">A desktop app that reads each photo's date and copies it into a tidy Year / Month folder tree. Your originals are never moved or deleted.</p>
    </div>

    <!-- Block B: folder tree visual -->
    <div class="ps-hero-b" style="animation:psFade .6s ease both;">
      <div style="background:var(--surface);border:1px solid var(--line);border-radius:20px;box-shadow:0 36px 70px -28px rgba(0,0,0,.4);overflow:hidden;">
        <div style="display:flex;align-items:center;gap:8px;padding:14px 18px;border-bottom:1px solid var(--line2);">
          <span style="width:11px;height:11px;border-radius:50%;background:var(--line);display:block;"></span>
          <span style="width:11px;height:11px;border-radius:50%;background:var(--line);display:block;"></span>
          <span style="width:11px;height:11px;border-radius:50%;background:var(--line);display:block;"></span>
          <span style="margin-left:8px;font-family:'Space Grotesk',sans-serif;font-size:12.5px;font-weight:600;color:var(--faint);" data-i18n="visual.title">Output folder</span>
        </div>
        <!-- before -->
        <div style="padding:16px 18px 6px;">
          <div style="font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--faint);margin-bottom:10px;" data-i18n="visual.before">Unsorted input</div>
          <div style="display:flex;flex-wrap:wrap;gap:7px;">
            <span style="font-size:12.5px;color:var(--muted);background:var(--bg);border:1px solid var(--line2);padding:5px 10px;border-radius:8px;">IMG_4821.jpg</span>
            <span style="font-size:12.5px;color:var(--muted);background:var(--bg);border:1px solid var(--line2);padding:5px 10px;border-radius:8px;">VID_0192.mp4</span>
            <span style="font-size:12.5px;color:var(--muted);background:var(--bg);border:1px solid var(--line2);padding:5px 10px;border-radius:8px;">IMG_9920.png</span>
            <span style="font-size:12.5px;color:var(--muted);background:var(--bg);border:1px solid var(--line2);padding:5px 10px;border-radius:8px;">IMG_5003.heic</span>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:10px;padding:14px 18px;">
          <span style="height:1px;flex:1;background:var(--line);"></span>
          <span style="display:inline-flex;align-items:center;gap:6px;font-size:11.5px;font-weight:700;color:var(--faint);">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
            <span data-i18n="visual.arrow">sorted by capture date</span>
          </span>
          <span style="height:1px;flex:1;background:var(--line);"></span>
        </div>
        <!-- after tree -->
        <div style="padding:4px 20px 22px;font-family:'Space Grotesk',sans-serif;font-size:13.5px;line-height:1.95;color:var(--ink);">
          <div style="display:flex;align-items:center;gap:8px;font-weight:600;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7a2 2 0 0 1 2-2h3l2 2h7a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>2024</div>
          <div style="margin-left:20px;display:flex;align-items:center;gap:8px;font-weight:600;color:var(--muted);"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7a2 2 0 0 1 2-2h3l2 2h7a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg><span data-i18n="visual.jun">06-June</span></div>
          <div style="margin-left:42px;display:flex;align-items:center;gap:8px;color:var(--faint);"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="9" cy="10" r="2"/><path d="M3 17l5-4 4 3 3-2 6 5"/></svg>IMG_4821.jpg</div>
          <div style="margin-left:42px;display:flex;align-items:center;gap:8px;color:var(--faint);"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="9" cy="10" r="2"/><path d="M3 17l5-4 4 3 3-2 6 5"/></svg>VID_0192.mp4</div>
          <div style="margin-left:20px;display:flex;align-items:center;gap:8px;font-weight:600;color:var(--muted);"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7a2 2 0 0 1 2-2h3l2 2h7a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg><span data-i18n="visual.jul">07-July</span></div>
          <div style="margin-left:42px;display:flex;align-items:center;gap:8px;color:var(--faint);"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="9" cy="10" r="2"/><path d="M3 17l5-4 4 3 3-2 6 5"/></svg>IMG_5003.heic</div>
          <div style="display:flex;align-items:center;gap:8px;font-weight:600;margin-top:2px;"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7a2 2 0 0 1 2-2h3l2 2h7a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>2023</div>
          <div style="margin-left:20px;display:flex;align-items:center;gap:8px;font-weight:600;color:var(--muted);"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7a2 2 0 0 1 2-2h3l2 2h7a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg><span data-i18n="visual.dec">12-December</span></div>
          <div style="margin-left:42px;display:flex;align-items:center;gap:8px;color:var(--faint);"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="9" cy="10" r="2"/><path d="M3 17l5-4 4 3 3-2 6 5"/></svg>IMG_9920.png</div>
        </div>
      </div>
    </div>

    <!-- Block C: CTA buttons + meta -->
    <div class="ps-hero-c" style="animation:psFade .5s ease both;">
      <div style="display:flex;gap:12px;flex-wrap:wrap;margin:0;">
        <a
          href="https://github.com/oscaroteromar/photos_sorter/releases/latest/download/Photos-Sorter-macos.dmg"
          target="_blank" rel="noopener"
          data-download-primary
          style="display:inline-flex;align-items:center;gap:9px;background:var(--inv);color:var(--invInk);text-decoration:none;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:15px;padding:14px 22px;border-radius:12px;">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12M7 11l5 4 5-4M5 20h14"/></svg>
          <span data-i18n-primary-label>Download for macOS</span>
        </a>
        <a href="#download" style="display:inline-flex;align-items:center;gap:8px;background:transparent;color:var(--ink);text-decoration:none;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:15px;padding:14px 20px;border-radius:12px;border:1px solid var(--line);"
          data-i18n="hero.otherCta">All platforms</a>
      </div>
      <div style="font-size:13.5px;color:var(--faint);margin:18px 0 0;font-weight:600;" data-i18n="hero.meta">Free &amp; open source · macOS, Windows &amp; Linux</div>
    </div>
  </section>

  <!-- ============ PROMISE ============ -->
  <section style="max-width:1140px;margin:28px auto;padding:0 28px;">
    <div class="ps-promise-band" style="background:var(--inv);color:var(--invInk);border-radius:26px;padding:46px 48px;display:flex;align-items:center;gap:40px;flex-wrap:wrap;">
      <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;opacity:.9;"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9 12l2 2 4-4"/></svg>
      <div style="flex:1;min-width:260px;">
        <div style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:clamp(24px,3vw,32px);letter-spacing:-.8px;line-height:1.1;" data-i18n="promise.title">Your originals never move.</div>
        <div style="font-size:16.5px;line-height:1.6;opacity:.78;margin-top:12px;max-width:46em;" data-i18n="promise.sub">Photos Sorter only ever copies. Nothing in your source folder is renamed, moved, or deleted — ever. No other data on your system is touched.</div>
      </div>
    </div>
  </section>

  <!-- ============ FEATURES ============ -->
  <section id="features" style="max-width:1140px;margin:0 auto;padding:64px 28px 20px;">
    <div style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--faint);" data-i18n="feat.eyebrow">Features</div>
    <h2 style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:clamp(27px,3.4vw,38px);letter-spacing:-.9px;color:var(--ink);margin:12px 0 6px;max-width:16em;" data-i18n="feat.title">Everything it does for your library</h2>
    <p style="font-size:17px;color:var(--muted);margin:0 0 38px;" data-i18n="feat.lead">Smart about dates, careful with your files.</p>

    <div class="ps-features-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;">
      <!-- F1 -->
      <div style="background:var(--surface);border:1px solid var(--line);border-radius:18px;padding:26px;">
        <div style="width:44px;height:44px;border-radius:12px;background:var(--bg);border:1px solid var(--line);display:flex;align-items:center;justify-content:center;color:var(--ink);"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4.5" width="18" height="16" rx="2.5"/><path d="M3 9h18M8 3v3M16 3v3"/><path d="M8.5 14.5l2 2 3.5-4"/></svg></div>
        <h3 style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:18px;color:var(--ink);margin:18px 0 8px;" data-i18n="feat.f1.title">Smart date detection</h3>
        <p style="font-size:14.5px;line-height:1.6;color:var(--muted);margin:0;" data-i18n="feat.f1.desc">Reads EXIF capture dates, Google Takeout sidecars and filesystem timestamps — in priority order — so every file lands on the right day.</p>
      </div>
      <!-- F2 -->
      <div style="background:var(--surface);border:1px solid var(--line);border-radius:18px;padding:26px;">
        <div style="width:44px;height:44px;border-radius:12px;background:var(--bg);border:1px solid var(--line);display:flex;align-items:center;justify-content:center;color:var(--ink);"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a2 2 0 0 1 2-2h3l2 2h4"/><rect x="3" y="8" width="18" height="11" rx="2"/><path d="M8 13h8M8 16h5"/></svg></div>
        <h3 style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:18px;color:var(--ink);margin:18px 0 8px;" data-i18n="feat.f2.title">Tidy folder trees</h3>
        <p style="font-size:14.5px;line-height:1.6;color:var(--muted);margin:0;" data-i18n="feat.f2.desc">Organises everything into Year / Month folders. Choose plain numbers (2024/06) or named months (2024/06-June).</p>
      </div>
      <!-- F3 -->
      <div style="background:var(--surface);border:1px solid var(--line);border-radius:18px;padding:26px;">
        <div style="width:44px;height:44px;border-radius:12px;background:var(--bg);border:1px solid var(--line);display:flex;align-items:center;justify-content:center;color:var(--ink);"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16a4 4 0 0 1 .5-8 5 5 0 0 1 9.4 1.4 3.5 3.5 0 0 1 .1 6.6"/><path d="M12 11v6M9.5 14.5L12 17l2.5-2.5"/></svg></div>
        <h3 style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:18px;color:var(--ink);margin:18px 0 8px;" data-i18n="feat.f3.title">Google Takeout ready</h3>
        <p style="font-size:14.5px;line-height:1.6;color:var(--muted);margin:0;" data-i18n="feat.f3.desc">Turn on Takeout mode and it reads photoTakenTime from each sidecar JSON. The JSON files are never copied across.</p>
      </div>
      <!-- F4 -->
      <div style="background:var(--surface);border:1px solid var(--line);border-radius:18px;padding:26px;">
        <div style="width:44px;height:44px;border-radius:12px;background:var(--bg);border:1px solid var(--line);display:flex;align-items:center;justify-content:center;color:var(--ink);"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 4-8 4-8-4 8-4z"/><path d="M4 12l8 4 8-4M4 16.5l8 4 8-4"/></svg></div>
        <h3 style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:18px;color:var(--ink);margin:18px 0 8px;" data-i18n="feat.f4.title">Every common format</h3>
        <p style="font-size:14.5px;line-height:1.6;color:var(--muted);margin:0;" data-i18n="feat.f4.desc">JPEG, PNG, HEIC/HEIF, MOV and MP4. Input folders are scanned recursively, however deep they go.</p>
      </div>
      <!-- F5 -->
      <div style="background:var(--surface);border:1px solid var(--line);border-radius:18px;padding:26px;">
        <div style="width:44px;height:44px;border-radius:12px;background:var(--bg);border:1px solid var(--line);display:flex;align-items:center;justify-content:center;color:var(--ink);"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9 12l2 2 4-4"/></svg></div>
        <h3 style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:18px;color:var(--ink);margin:18px 0 8px;" data-i18n="feat.f5.title">No overwrites, ever</h3>
        <p style="font-size:14.5px;line-height:1.6;color:var(--muted);margin:0;" data-i18n="feat.f5.desc">Duplicate names are auto-renamed — IMG_001.jpg becomes IMG_001 (1).jpg. Nothing is lost.</p>
      </div>
      <!-- F6 -->
      <div style="background:var(--surface);border:1px solid var(--line);border-radius:18px;padding:26px;">
        <div style="width:44px;height:44px;border-radius:12px;background:var(--bg);border:1px solid var(--line);display:flex;align-items:center;justify-content:center;color:var(--ink);"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18"/></svg></div>
        <h3 style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:18px;color:var(--ink);margin:18px 0 8px;" data-i18n="feat.f6.title">Bilingual &amp; remembered</h3>
        <p style="font-size:14.5px;line-height:1.6;color:var(--muted);margin:0;" data-i18n="feat.f6.desc">Full English and Spanish UI with localised month names, and your settings saved between runs.</p>
      </div>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section id="how" style="max-width:1140px;margin:0 auto;padding:60px 28px 20px;">
    <div style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--faint);" data-i18n="how.eyebrow">How it works</div>
    <h2 style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:clamp(27px,3.4vw,38px);letter-spacing:-.9px;color:var(--ink);margin:12px 0 38px;max-width:14em;" data-i18n="how.title">Three steps to a sorted library</h2>
    <div class="ps-how-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:22px;">
      <div data-step="0" style="border-top:2px solid var(--ink);padding-top:22px;">
        <div style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:15px;color:var(--faint);" data-step-n>01</div>
        <h3 style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:20px;color:var(--ink);margin:14px 0 8px;" data-step-title>Pick a folder</h3>
        <p style="font-size:15px;line-height:1.6;color:var(--muted);margin:0;" data-step-desc>Point Photos Sorter at any folder of photos and videos — nested subfolders included.</p>
      </div>
      <div data-step="1" style="border-top:2px solid var(--ink);padding-top:22px;">
        <div style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:15px;color:var(--faint);" data-step-n>02</div>
        <h3 style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:20px;color:var(--ink);margin:14px 0 8px;" data-step-title>Choose your options</h3>
        <p style="font-size:15px;line-height:1.6;color:var(--muted);margin:0;" data-step-desc>Month format, language and Google Takeout mode. Set them once — they're remembered.</p>
      </div>
      <div data-step="2" style="border-top:2px solid var(--ink);padding-top:22px;">
        <div style="font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:15px;color:var(--faint);" data-step-n>03</div>
        <h3 style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:20px;color:var(--ink);margin:14px 0 8px;" data-step-title>Get a sorted copy</h3>
        <p style="font-size:15px;line-height:1.6;color:var(--muted);margin:0;" data-step-desc>A clean Year / Month tree appears in your output folder. Originals stay exactly where they are.</p>
      </div>
