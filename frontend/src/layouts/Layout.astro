---
export interface Props {
  title?: string;
  description?: string;
}
const { title = 'Photos Sorter', description = 'Sort your photos by the day they were taken.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Anti-FOUC: set theme before first paint -->
  <script is:inline>
    (function() {
      try {
        var theme = localStorage.getItem('ps_theme');
        if (!theme) {
          theme = (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) ? 'dark' : 'light';
        }
        document.documentElement.setAttribute('data-theme', theme);
      } catch(e) {}
    })();
  </script>

  <style is:global>
    :root {
      --bg: #F4F4F5;
      --surface: #FFFFFF;
      --ink: #16181D;
      --muted: #5A5F69;
      --faint: #9A9EA6;
      --line: rgba(22,24,29,.12);
      --line2: rgba(22,24,29,.06);
      --inv: #16181D;
      --invInk: #FFFFFF;
    }
    :root[data-theme="dark"] {
      --bg: #0D0E12;
      --surface: #16181F;
      --ink: #F3F4F6;
      --muted: #A7ABB6;
      --faint: #6B6F7A;
      --line: rgba(255,255,255,.12);
      --line2: rgba(255,255,255,.05);
      --inv: #F3F4F6;
      --invInk: #16181D;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    html, body { margin: 0; background: var(--bg); }
    body { font-family: 'Nunito', sans-serif; -webkit-font-smoothing: antialiased; }
    @keyframes psFade { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
    :root[data-anim] *, :root[data-anim] *::before, :root[data-anim] *::after {
      transition: background-color .45s ease, border-color .45s ease, color .38s ease, fill .42s ease, stroke .42s ease, box-shadow .45s ease;
    }
    #ps-main { transition: opacity .3s ease; }
    @media (prefers-reduced-motion: reduce) {
      :root[data-anim] *, :root[data-anim] *::before, :root[data-anim] *::after { transition: none !important; }
      #ps-main { transition: none !important; }
    }
  </style>
</head>
<body>
  <!-- psIcon SVG symbol defs (inline, reusable anywhere via <use href="#psIcon">) -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <symbol id="psIcon" viewBox="0 0 512 512">
        <rect x="16" y="16" width="480" height="480" rx="116" fill="#F4F4F5" />
        <g transform="rotate(-8 198 286)">
          <rect x="150" y="150" width="16" height="34" rx="8" fill="#16181D" />
          <rect x="226" y="150" width="16" height="34" rx="8" fill="#16181D" />
          <rect x="110" y="172" width="190" height="190" rx="26" fill="#FFFFFF" stroke="#16181D" stroke-width="11" />
          <path d="M110 198 a26 26 0 0 1 26 -26 l138 0 a26 26 0 0 1 26 26 l0 24 l-190 0 Z" fill="#16181D" />
          <g fill="#9A9EA6">
            <circle cx="150" cy="262" r="9" /><circle cx="190" cy="262" r="9" /><circle cx="230" cy="262" r="9" /><circle cx="270" cy="262" r="9" />
            <circle cx="150" cy="302" r="9" /><circle cx="270" cy="302" r="9" />
            <circle cx="150" cy="338" r="9" /><circle cx="190" cy="338" r="9" />
          </g>
          <rect x="206" y="286" width="34" height="34" rx="11" fill="#16181D" />
        </g>
        <g transform="rotate(7 318 306)">
          <rect x="216" y="210" width="196" height="196" rx="26" fill="#FFFFFF" stroke="#16181D" stroke-width="11" />
          <clipPath id="psClip"><rect x="228" y="222" width="172" height="172" rx="15" /></clipPath>
          <g clip-path="url(#psClip)">
            <rect x="228" y="222" width="172" height="172" fill="#ECEDF0" />
            <circle cx="362" cy="258" r="21" fill="#16181D" />
            <path d="M228 360 L274 312 L308 346 L350 302 L400 350 L400 394 L228 394 Z" fill="#595D66" />
            <path d="M228 372 L268 332 L308 366 L356 320 L400 358 L400 394 L228 394 Z" fill="#16181D" />
          </g>
        </g>
      </symbol>
    </defs>
  </svg>

  <slot />
</body>
</html>
